generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum ExamStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  GRADED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  profile     Profile?
  enrollments Enrollment[]
  examAttempts ExamAttempt[]
  xp          XP?
  badges      UserBadge[]
  reviews     Review[]
  teacherReviews TeacherReview[] @relation("TeacherReviews")
  teacherReviewsGiven TeacherReview[]
  notifications Notification[]
  certificates Certificate[]
  createdCourses Course[]     @relation("TeacherCourses")
  createdQuizzes Quiz[]       @relation("TeacherQuizzes")
  createdExams  Exam[]       @relation("TeacherExams")
  discussions  Discussion[]
  replies      Reply[]
  discussionVotes DiscussionVote[]
  replyVotes   ReplyVote[]
  rewardRedemptions RewardRedemption[]
  bookmarks Bookmark[]
  activityLogs ActivityLog[]
  streakMilestones StreakMilestone[]
  searchQueries SearchQuery[]
  teacherApplication TeacherApplication?
  reviewedApplications TeacherApplication[] @relation("ApplicationReviewer")

  @@map("users")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  avatarUrl String?
  phone     String?
  address   String?
  dateOfBirth DateTime?
  profileVisibility String @default("public")
  showOnLeaderboard Boolean @default(true)
  shareLearningActivity Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]

  @@map("categories")
}

model Course {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  shortDescription String?
  thumbnailUrl  String?
  price         Float    @default(0)
  isPublished   Boolean  @default(false)
  categoryId    String?
  teacherId     String
  difficulty    String   @default("beginner")
  duration      Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  teacher     User          @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: Cascade)
  modules     Module[]
  enrollments Enrollment[]
  reviews     Review[]
  certificates Certificate[]
  discussions Discussion[]
  teacherReviews TeacherReview[]
  bookmarks Bookmark[]
  activityLogs ActivityLog[]

  @@index([title])
  @@index([difficulty])
  @@index([categoryId])
  @@index([teacherId])
  @@map("courses")
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int
  courseId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course   Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  description String?
  content     String   @db.Text
  videoUrl    String?
  duration    Int?
  order       Int
  moduleId    String
  isFree      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  discussions Discussion[]
  bookmarks Bookmark[]
  activityLogs ActivityLog[]

  @@index([title])
  @@index([moduleId])
  @@map("lessons")
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId   String
  status    EnrollmentStatus @default(ACTIVE)
  progress  Float            @default(0)
  enrolledAt DateTime        @default(now())
  completedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, status])
  @@index([courseId, status])
  @@map("enrollments")
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  lessonId    String?
  courseId    String?
  teacherId   String
  timeLimit   Int?
  passingScore Float   @default(70)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher   User       @relation("TeacherQuizzes", fields: [teacherId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("quizzes")
}

model Question {
  id        String   @id @default(cuid())
  quizId    String
  text      String   @db.Text
  type      String   @default("multiple_choice")
  options   Json
  correctAnswer String
  points    Int      @default(1)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Exam {
  id            String     @id @default(cuid())
  title         String
  description   String?
  courseId      String?
  teacherId     String
  timeLimit     Int?
  passingScore  Float      @default(70)
  maxAttempts   Int        @default(1)
  isPublished   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  teacher      User           @relation("TeacherExams", fields: [teacherId], references: [id], onDelete: Cascade)
  examAttempts ExamAttempt[]

  @@map("exams")
}

model ExamAttempt {
  id         String     @id @default(cuid())
  examId     String
  userId     String
  score      Float?
  status     ExamStatus @default(PENDING)
  startedAt  DateTime?
  submittedAt DateTime?
  answers    Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  exam  Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
  @@index([userId, status])
  @@map("exam_attempts")
}

model Certificate {
  id              String    @id @default(cuid())
  verificationId  String    @unique @default(cuid())
  userId          String
  courseId        String
  examId          String?
  studentName     String
  courseName      String
  teacherName     String
  grade           String?
  certificateUrl  String
  status          String    @default("VALID")
  revokedAt       DateTime?
  revokedReason   String?
  expiresAt       DateTime?
  issuedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  logs   VerificationLog[]

  @@unique([userId, courseId])
  @@index([status])
  @@index([studentName])
  @@index([courseName])
  @@index([verificationId])
  @@map("certificates")
}

model VerificationLog {
  id              String   @id @default(cuid())
  certificateId   String
  verifiedAt      DateTime @default(now())
  ipAddress       String?
  userAgent       String?
  verifierName    String?
  status          String   @default("VALID")

  certificate Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@index([certificateId, verifiedAt])
  @@map("verification_logs")
}

model XP {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?
  criteria    String?
  createdAt   DateTime @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  rank      Int?
  period    String   @default("all_time")
  updatedAt DateTime @updatedAt

  @@map("leaderboards")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Sponsor {
  id           String   @id @default(cuid())
  name         String
  logoUrl      String?
  websiteUrl   String?
  contactEmail String?
  tier         String   @default("basic")
  description  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rewards Reward[]

  @@map("sponsors")
}

enum RewardType {
  COUPON
  DISCOUNT
  PROMO
}

model Reward {
  id          String     @id @default(cuid())
  title       String
  description String?
  pointsCost  Int
  type        RewardType @default(COUPON)
  value       String     @default("")
  imageUrl    String?
  isActive    Boolean    @default(true)
  stock       Int?
  sponsorId   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  sponsor     Sponsor?            @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  redemptions RewardRedemption[]

  @@map("rewards")
}

model RewardRedemption {
  id          String   @id @default(cuid())
  userId      String
  rewardId    String
  pointsSpent Int
  code        String?
  status      String   @default("pending")
  redeemedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@map("reward_redemptions")
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  courseId    String
  rating     Int
  comment    String?  @db.Text
  isEdited   Boolean  @default(false)
  isHidden   Boolean  @default(false)
  isReported Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@map("reviews")
}

model TeacherReview {
  id         String   @id @default(cuid())
  userId     String
  teacherId   String
  courseId    String?
  rating     Int
  comment    String?  @db.Text
  isEdited   Boolean  @default(false)
  isHidden   Boolean  @default(false)
  isReported Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacher User   @relation("TeacherReviews", fields: [teacherId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@unique([userId, teacherId])
  @@index([teacherId])
  @@map("teacher_reviews")
}

model Discussion {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  userId    String
  courseId  String?
  lessonId  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson   Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  replies  Reply[]
  votes    DiscussionVote[]

  @@index([courseId])
  @@index([lessonId])
  @@map("discussions")
}

model Reply {
  id           String   @id @default(cuid())
  content      String   @db.Text
  userId       String
  discussionId String
  parentId     String?
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parent     Reply?     @relation("ReplyReplies", fields: [parentId], references: [id])
  replies    Reply[]    @relation("ReplyReplies")
  votes      ReplyVote[]

  @@map("replies")
}

model DiscussionVote {
  id           String   @id @default(cuid())
  userId       String
  discussionId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@map("discussion_votes")
}

model ReplyVote {
  id      String   @id @default(cuid())
  userId  String
  replyId String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@map("reply_votes")
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model TeacherApplication {
  id                    String             @id @default(cuid())
  userId                String             @unique
  fullName              String
  profilePhoto          String?
  bio                   String?            @db.Text
  qualifications        String?            @db.Text
  experience            String?            @db.Text
  linkedIn              String?
  portfolioWebsite      String?
  socialLinks           Json?
  expertiseArea         String?
  sampleCourseProposal  String?            @db.Text
  status                ApplicationStatus  @default(SUBMITTED)
  adminNotes            Json?
  reviewedBy            String?
  reviewedAt            DateTime?
  rejectionReason       String?            @db.Text
  changesRequested      String?            @db.Text
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([status, createdAt])
  @@map("teacher_applications")
}

enum ActivityType {
  LESSON_WATCHED
  QUIZ_PASSED
  EXAM_TAKEN
  COURSE_COMPLETED
}

model ActivityLog {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  courseId   String?
  lessonId  String?
  xpEarned  Int          @default(0)
  createdAt DateTime     @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model StreakMilestone {
  id        String   @id @default(cuid())
  userId    String
  days      Int
  xpAwarded Int      @default(0)
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, days])
  @@map("streak_milestones")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  courseId   String?
  lessonId  String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId])
  @@map("bookmarks")
}

model SearchQuery {
  id        String   @id @default(cuid())
  query     String
  userId    String?
  count     Int      @default(1)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([query])
  @@index([count])
  @@index([userId, createdAt])
  @@map("search_queries")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}
